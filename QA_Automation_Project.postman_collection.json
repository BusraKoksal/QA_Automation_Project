  "item": [
    {
      "name": "Get_Post_Detail",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// 1. Kontrol: Sayfa başarılı açıldı mı? (Durum kodu 200 mü?)\r",
              "pm.test(\"Status code is 200 - Başarılı\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "// 2. Kontrol: Gelen veri doğru mu? (ID 1 mi gelmiş?)\r",
              "pm.test(\"ID kontrolü: Gelen veri 1 olmalı\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.id).to.eql(1);\r",
              "});\r",
              "// 3. Kontrol: Cevap içeriğinde 'title' diye bir alan var mı?\r",
              "pm.test(\"Title alanı mevcut mu?\", function () {\r",
              "    pm.expect(pm.response.text()).to.include(\"title\");\r",
              "});\r",
              "// 4. Kontrol: Hız testi (Cevap 500ms'den kısa sürmeli)\r",
              "pm.test(\"Response time is less than 500ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(500);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
